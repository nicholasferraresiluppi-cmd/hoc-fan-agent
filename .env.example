# HOC Fan Agent — Variabili d'ambiente
# Queste vanno configurate su Vercel Dashboard → Settings → Environment Variables

# API Key Anthropic (dal server, NON dall'utente)
ANTHROPIC_API_KEY=sk-ant-...

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Upstash Redis (connesso tramite Vercel Marketplace)
# KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN — aggiunti automaticamente

# === Content Pipeline (modulo isolato, multi-creator) ===
# Chiave AES-256-GCM per cifrare i BOT_TOKEN Telegram dei creator salvati in KV.
# 32 byte in hex (64 caratteri). Generala con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_TOKEN_ENCRYPTION_KEY=

# Secret per autenticare le chiamate del cron Vercel (Authorization: Bearer <secret>)
CONTENT_CRON_SECRET=

# (Opzionale) Override del modello Anthropic per la generazione draft
CONTENT_ANTHROPIC_MODEL=claude-opus-4-7

# === CreatorsPro (sync sales/shift — src/lib/creatorspro-api.js) ===
CREATORSPRO_API_BASE_URL=https://api.houseofcreators.com
CREATORSPRO_BOT_EMAIL=
CREATORSPRO_BOT_PASSWORD=

# === Infloww (revenue live + reconcile — src/lib/infloww-api.js) ===
INFLOWW_API_BASE_URL=
INFLOWW_API_KEY=
INFLOWW_OID=

# === Admin bootstrap + cron ===
# Lista user id Clerk admin separati da virgola (poi gestibili da /admin/access)
HOC_ADMIN_USER_IDS=
# Secret per i cron Vercel (leaderboard/leghe snapshot)
CRON_SECRET=

# Ingest CSV Infloww headless (bridge locale → HOC Pro)
INFLOWW_INGEST_SECRET=

# === Alert operativi — mail del lunedì (docs/ALERT_OPERATIVI.md) ===
# API key Resend per il digest settimanale (parte solo se ci sono critici aperti)
RESEND_API_KEY=
# Destinatari, separati da virgola
HOC_ALERTS_EMAILS=
# (Opzionale) Mittente custom dopo la verifica dominio su Resend
# HOC_ALERTS_FROM="HOC Pro <alerts@houseofcreators.com>"
